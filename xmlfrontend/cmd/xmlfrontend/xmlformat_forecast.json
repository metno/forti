                    "name": "temperatureProbability",
                    "ncName": "air_temperature_confidence_code",
                    "attrs": [
                        {
                            "name": "unit",
                            "value": "probabilitycode"
                        }
                    ],
                    "computedAttrs": [
                        {
                            "name": "value",
                            "func": "to_int"
                        }
                    ]
                },
                {
                    "name": "windProbability",
                    "ncName": "wind_speed_confidence_code",
                    "attrs": [
                        {
                            "name": "unit",
